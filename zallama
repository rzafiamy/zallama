def _color(text: str, color_code: str) -> str:
    if sys.stdout.isatty():
        return f"{color_code}{text}{RESET}"
    return text


def _ok(msg: str): print(f"{_color('●', F_TEAL)} {msg}")
def _warn(msg: str): print(f"{_color('⚠', F_ORANGE)} {msg}", file=sys.stderr)
def _err(msg: str): print(f"{_color('✗', F_RED)} {msg}", file=sys.stderr)
def _info(msg: str): print(f"{_color('ℹ', F_BLUE)} {msg}")


def _print_table(headers: list[str], rows: list[list[str]], col_aligns: list[str] | None = None):
    """Render a clean Fluent-style table with elegant Unicode borders."""
    widths = [len(h) for h in headers]
    for row in rows:
        for idx, cell in enumerate(row):
            clean_cell = re.sub(r'\033\[[0-9;]*m', '', str(cell))
            widths[idx] = max(widths[idx], len(clean_cell))
    
    c_tl, c_tr, c_bl, c_br = "┌", "┐", "└", "┘"
    c_hl, c_vl, c_t = "─", "│", "┬"
    c_b, c_l, c_r = "┴", "├", "┤"
    c_x = "┼"
    
    top = c_tl + c_hl.join(c_hl * (w + 2) for w in widths) + c_tr
    print(_color(top, F_DIM))
    
    header_str = c_vl + c_vl.join(f" {h:<{widths[i]}} " for i, h in enumerate(headers)) + c_vl
    print(header_str)
    
    sep = c_l + c_x.join(c_hl * (w + 2) for w in widths) + c_r
    print(_color(sep, F_DIM))
    
    for row in rows:
        line_parts = []
        for i, cell in enumerate(row):
            clean_cell = re.sub(r'\033\[[0-9;]*m', '', str(cell))
            padding = widths[i] - len(clean_cell)
            align = col_aligns[i] if col_aligns else "left"
            if align == "right":
                line_parts.append(f" {' ' * padding}{cell} ")
            else:
                line_parts.append(f" {cell}{' ' * padding} ")
        print(c_vl + c_vl.join(line_parts) + c_vl)
        
    bot = c_bl + c_hl.join(c_hl * (w + 2) for w in widths) + c_br
    print(_color(bot, F_DIM))


# ---------------------------------------------------------------------------
# Markdown rendering for the interactive chat
# ---------------------------------------------------------------------------
_ANSI_RE = re.compile(r'\033\[[0-9;]*m')


def _visible_len(s: str) -> int:
    """Length of a string ignoring ANSI escape codes."""
    return len(_ANSI_RE.sub('', s))


def _term_width(default: int = 80) -> int:
    """Terminal width in columns, with a sane fallback for non-ttys/pipes."""
    import shutil
    try:
        cols = shutil.get_terminal_size((default, 24)).columns
    except Exception:
        cols = default
    return max(40, cols)


def _wrap_ansi(text: str, width: int) -> list[str]:
    """Word-wrap a single line to `width` visible columns, ANSI-aware.

    Splits on spaces, measuring with _visible_len so color codes don't count
    toward the column budget. Words longer than `width` (e.g. URLs) are left
    intact on their own line rather than hard-split mid-escape.
    """
    words = text.split(" ")
    lines: list[str] = []
    cur = ""
    cur_len = 0
    for word in words:
        wlen = _visible_len(word)
        if cur and cur_len + 1 + wlen > width:
            lines.append(cur)
            cur, cur_len = word, wlen
        else:
            if cur:
                cur += " " + word
                cur_len += 1 + wlen
            else:
                cur, cur_len = word, wlen
    if cur or not lines:
        lines.append(cur)
    return lines


def _render_inline_md(text: str) -> str:
    """Apply inline markdown styling: **bold**, *italic*, `code`, links.

    Order matters: code spans are protected first so their contents aren't
    re-styled, then bold before italic so `**x**` isn't eaten by the italic rule.
    """
    # Inline code — teal, protect contents from further styling via placeholders.
    code_spans: list[str] = []

    def _stash_code(m: re.Match) -> str:
        code_spans.append(m.group(1))
        return f"\x00{len(code_spans) - 1}\x00"

    text = re.sub(r'`([^`]+)`', _stash_code, text)
    # Links [label](url) -> label (dim url)
    text = re.sub(
        r'\[([^\]]+)\]\(([^)]+)\)',
        lambda m: f"{F_BLUE}{m.group(1)}{RESET} {F_DIM}({m.group(2)}){RESET}",
        text,
    )
    # Bold then italic.
    text = re.sub(r'\*\*([^*]+)\*\*', lambda m: f"{BOLD}{m.group(1)}{RESET}", text)
    text = re.sub(r'__([^_]+)__', lambda m: f"{BOLD}{m.group(1)}{RESET}", text)
    text = re.sub(r'(?<!\*)\*([^*\n]+)\*(?!\*)', lambda m: f"{F_GRAY}{m.group(1)}{RESET}", text)
    # Restore code spans (styled, after everything else).
    text = re.sub(
        r'\x00(\d+)\x00',
        lambda m: f"{F_TEAL}{code_spans[int(m.group(1))]}{RESET}",
        text,
    )
    return text


def _render_markdown(md: str, width: int) -> list[str]:
    """Render markdown text into a list of styled, word-wrapped lines.

    A deliberately small renderer (no deps): headings, bullet/numbered lists,
    blockquotes, fenced code blocks, horizontal rules, and inline styling.
    Lines are wrapped to `width` visible columns.
    """
    out: list[str] = []
    in_fence = False
    for raw in md.split("\n"):
        line = raw.rstrip("\n")

        # Fenced code blocks: render verbatim (no wrap, no inline styling).
        fence = re.match(r'^\s*```(.*)$', line)
        if fence:
            in_fence = not in_fence
            out.append(f"{F_DIM}{'─' * min(width, 40)}{RESET}")
            continue
        if in_fence:
            out.append(f"{F_TEAL}{line}{RESET}")
            continue

        if not line.strip():
            out.append("")
            continue

        # Horizontal rule.
        if re.match(r'^\s*([-*_])\1{2,}\s*$', line):
            out.append(f"{F_DIM}{'─' * width}{RESET}")
            continue

        # Headings.
        h = re.match(r'^(#{1,6})\s+(.*)$', line)
        if h:
            txt = _render_inline_md(h.group(2))
            for wl in _wrap_ansi(txt, width):
                out.append(f"{BOLD}{F_BLUE}{wl}{RESET}")
            continue

        # Blockquote.
        if line.lstrip().startswith(">"):
            txt = _render_inline_md(line.lstrip()[1:].lstrip())
            for wl in _wrap_ansi(txt, width - 2):
                out.append(f"{F_DIM}▏{RESET} {F_GRAY}{wl}{RESET}")
            continue

        # Bullet list.
        b = re.match(r'^(\s*)[-*+]\s+(.*)$', line)
        if b:
            indent = " " * len(b.group(1))
            txt = _render_inline_md(b.group(2))
            wrapped = _wrap_ansi(txt, width - len(indent) - 2)
            out.append(f"{indent}{F_TEAL}•{RESET} {wrapped[0]}")
            for wl in wrapped[1:]:
                out.append(f"{indent}  {wl}")
            continue

        # Numbered list.
        n = re.match(r'^(\s*)(\d+)\.\s+(.*)$', line)
        if n:
            indent = " " * len(n.group(1))
            marker = f"{n.group(2)}."
            txt = _render_inline_md(n.group(3))
            wrapped = _wrap_ansi(txt, width - len(indent) - len(marker) - 1)
            out.append(f"{indent}{F_TEAL}{marker}{RESET} {wrapped[0]}")
            for wl in wrapped[1:]:
                out.append(f"{indent}{' ' * (len(marker) + 1)}{wl}")
            continue

        # Plain paragraph.
        for wl in _wrap_ansi(_render_inline_md(line), width):
            out.append(wl)
    return out


def _print_framed(md: str, label: str, label_color: str) -> None:
    """Render markdown inside a left-margin frame with a vertical rule.

    The whole block is indented and gutter-railed so the assistant's reply is
    visually contained — aligned, framed, and separated from the prompt.
    """
    margin = 2
    gutter = f"{label_color}▏{RESET}"
    width = _term_width()
    content_width = max(40, width - margin - 2)

    print(f"\n{' ' * margin}{BOLD}{label_color}{label}{RESET}")
    for line in _render_markdown(md, content_width):
        print(f"{' ' * margin}{gutter} {line}" if line else f"{' ' * margin}{gutter}")


