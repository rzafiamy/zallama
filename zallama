def cmd_zvec(args: list[str]):
    """Manage the built-in zvec vector store (RAG retrieval)."""
    sub = args[0] if args else "help"
    rest = args[1:]

    if sub in ("help", "-h", "--help"):
        print(f"\n{BOLD}{F_BLUE} zallama zvec — vector store (RAG){RESET}")
        print(f"  {_color('zvec collections', CYAN):<48}{DIM}List collections{RESET}")
        print(f"  {_color('zvec create <name> [--model M] [--dim N]', CYAN):<48}{DIM}Create a collection{RESET}")
        print(f"  {_color('zvec drop <name>', CYAN):<48}{DIM}Delete a collection{RESET}")
        print(f"  {_color('zvec upsert <name> <file>', CYAN):<48}{DIM}Add docs (one per line, or JSON array){RESET}")
        print(f"  {_color('zvec query <name> <text> [--top-k K] [--rerank M]', CYAN):<48}{DIM}Semantic search{RESET}")
        print()
        return

    if sub == "collections":
        r = _api("GET", "/v1/zvec/collections")
        data = r.json().get("data", [])
        if not data:
            _info("No collections yet. Create one with: zallama zvec create <name>")
            return
        headers = ["NAME", "EMBEDDING MODEL", "DIM", "DOCS"]
        rows = [[c["name"], c["embedding_model"], str(c["dim"]), str(c["count"])] for c in data]
        print(f"\n{BOLD}{F_BLUE} zvec Collections{RESET}")
        _print_table(headers, rows)
        print()
        return

    if sub == "create":
        if not rest:
            _err("Usage: zallama zvec create <name> [--model M] [--dim N]")
            sys.exit(1)
        name = rest[0]
        body = {"name": name}
        if "--model" in rest:
            body["embedding_model"] = rest[rest.index("--model") + 1]
        if "--dim" in rest:
            body["dim"] = int(rest[rest.index("--dim") + 1])
        r = _api("POST", "/v1/zvec/collections", body)
        if r.status_code >= 400:
            _err(r.json().get("detail", r.text)); sys.exit(1)
        c = r.json()
        _ok(f"Created collection '{c['name']}' (model={c['embedding_model']}, dim={c['dim']})")
        return

    if sub == "drop":
        if not rest:
            _err("Usage: zallama zvec drop <name>"); sys.exit(1)
        r = _api("DELETE", f"/v1/zvec/collections/{rest[0]}")
        if r.status_code >= 400:
            _err(r.json().get("detail", r.text)); sys.exit(1)
        _ok(f"Deleted collection '{rest[0]}'")
        return

    if sub == "upsert":
        if len(rest) < 2:
            _err("Usage: zallama zvec upsert <name> <file>"); sys.exit(1)
        name, path = rest[0], rest[1]
        text = Path(path).read_text(encoding="utf-8")
        stripped = text.lstrip()
        if stripped.startswith("[") or stripped.startswith("{"):
            docs = json.loads(text)
            if isinstance(docs, dict):
                docs = [docs]
        else:
            docs = [line.strip() for line in text.splitlines() if line.strip()]
        r = _api("POST", f"/v1/zvec/{name}/upsert", {"documents": docs})
        if r.status_code >= 400:
            _err(r.json().get("detail", r.text)); sys.exit(1)
        _ok(f"Upserted {r.json().get('upserted', 0)} document(s) into '{name}'")
        return

    if sub == "query":
        if len(rest) < 2:
            _err("Usage: zallama zvec query <name> <text> [--top-k K] [--rerank M]"); sys.exit(1)
        name = rest[0]
        # Everything that isn't a flag is the query text.
        flags = {"--top-k", "--rerank"}
        text_parts = []
        i = 1
        body = {}
        while i < len(rest):
            if rest[i] == "--top-k":
                body["top_k"] = int(rest[i + 1]); i += 2
            elif rest[i] == "--rerank":
                body["rerank_model"] = rest[i + 1]; i += 2
            else:
                text_parts.append(rest[i]); i += 1
        body["query"] = " ".join(text_parts)
        r = _api("POST", f"/v1/zvec/{name}/query", body)
        if r.status_code >= 400:
            _err(r.json().get("detail", r.text)); sys.exit(1)
        results = r.json().get("results", [])
        if not results:
            _info("No results."); return
        print(f"\n{BOLD}{F_BLUE} Results for '{body['query']}' in '{name}'{RESET}")
        for res in results:
            score = res.get("score")
            score_s = f"{score:.4f}" if isinstance(score, (int, float)) else "?"
            print(f"  {_color(score_s, F_TEAL)}  {_color(res['id'], DIM)}")
            snippet = res["text"].replace("\n", " ")
            print(f"      {snippet[:120]}{'…' if len(snippet) > 120 else ''}")
        print()
        return

    _err(f"Unknown zvec subcommand: '{sub}'")
    _info("Run 'zallama zvec help' for usage.")
    sys.exit(1)


