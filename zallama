def _api(method: str, path: str, data: dict | None = None, stream=False):
    if not HAS_REQUESTS:
        _err("'requests' library not installed. Run: pip install requests")
        sys.exit(1)
    url = f"{ZALLAMA_HOST}{path}"
    try:
        if method == "GET":
            r = requests.get(url, timeout=10, stream=stream)
        elif method == "POST":
            r = requests.post(url, json=data, timeout=None, stream=stream)
        elif method == "DELETE":
            r = requests.delete(url, timeout=10)
        else:
            raise ValueError(f"Unknown method: {method}")
        return r
    except requests.exceptions.ConnectionError:
        _err(f"Cannot connect to Zallama at {ZALLAMA_HOST}")
        _info("Run 'zallama serve' to start the daemon.")
        sys.exit(1)


def _check_daemon():
    try:
        r = requests.get(f"{ZALLAMA_HOST}/health", timeout=3)
        return r.status_code == 200
    except Exception:
        return False


