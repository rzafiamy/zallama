import threading

class Spinner:
    def __init__(self, message="Assistant is thinking..."):
        self.message = message
        self.running = False
        self.thread = None

    def _spin(self):
        chars = ["⠋", "⠙", "⠹", "⠸", "⠼", "⠴", "⠦", "⠧", "⠇", "⠏"]
        idx = 0
        while self.running:
            sys.stdout.write(f"\r{_color(chars[idx], GREEN)} {self.message}")
            sys.stdout.flush()
            idx = (idx + 1) % len(chars)
            time.sleep(0.1)
        # Clear spinner line completely
        sys.stdout.write("\r" + " " * (len(self.message) + 10) + "\r")
        sys.stdout.flush()

    def start(self):
        self.running = True
        self.thread = threading.Thread(target=self._spin, daemon=True)
        self.thread.start()

    def stop(self):
        if self.running:
            self.running = False
            if self.thread:
                self.thread.join()

def cmd_run(args: list[str]):
    """Interactive chat: zallama run <model>"""
    if not args:
        _err("Usage: zallama run <model-name>")
        sys.exit(1)
    model = args[0]

    print(_color(f"\n🦙 Zallama — {model}", CYAN + BOLD))
    print(_color("Type your message. Use /exit or Ctrl+C to quit.\n", DIM))

    # First, ensure the model is loaded (may take a moment)
    print(_color(f"⏳ Loading model '{model}'...", YELLOW), end="", flush=True)
    r = _api("POST", f"/api/models/{model}/load")
    if r.status_code != 200:
        print()
        _err(f"Failed to load model: {r.json().get('detail', r.text)}")
        sys.exit(1)
    print(_color(" ready!", GREEN))

    history = []

    while True:
        try:
            user_input = input(_color("\nYou: ", CYAN + BOLD)).strip()
        except (KeyboardInterrupt, EOFError):
            print("\n" + _color("Goodbye! 👋", DIM))
            break

        if not user_input:
            continue
        if user_input.lower() in ("/exit", "/quit", "exit", "quit"):
            print(_color("Goodbye! 👋", DIM))
            break
        if user_input == "/clear":
            history = []
            print(_color("History cleared.", DIM))
            continue

        history.append({"role": "user", "content": user_input})

        payload = {"model": model, "messages": history, "stream": True}
        spinner = Spinner("Assistant is thinking...")
        spinner.start()

        full_response = ""
        try:
            r = requests.post(
                f"{ZALLAMA_HOST}/v1/chat/completions",
                json=payload,
                stream=True,
                timeout=None,
            )
            
            if r.status_code != 200:
                spinner.stop()
                try:
                    err_msg = r.json().get("detail", r.text)
                except Exception:
                    err_msg = r.text
                print(_color(f"\nError: {err_msg}", RED))
                continue

            buffer = b""
            spinner_stopped = False

            done = False
            for chunk in r.iter_content(chunk_size=None):
                if not spinner_stopped:
                    spinner.stop()
                    print(_color("Assistant: ", GREEN + BOLD), end="", flush=True)
                    spinner_stopped = True

                buffer += chunk
                while b"\n" in buffer:
                    line_bytes, buffer = buffer.split(b"\n", 1)
                    line_str = line_bytes.decode("utf-8", errors="ignore").strip()
                    if not line_str:
                        continue
                    if line_str.startswith("data: "):
                        text = line_str[6:]
                    else:
                        text = line_str

                    if text == "[DONE]":
                        done = True
                        break

                    try:
                        chunk_json = json.loads(text)
                        delta = chunk_json["choices"][0]["delta"]
                        
                        # Support thinking / reasoning models
                        reasoning_content = delta.get("reasoning_content", "")
                        delta_content = delta.get("content", "")
                        
                        if reasoning_content:
                            print(_color(reasoning_content, DIM), end="", flush=True)
                            full_response += reasoning_content
                        elif delta_content:
                            print(delta_content, end="", flush=True)
                            full_response += delta_content
                    except Exception:
                        pass
                if done:
                    break

        except Exception as e:
            spinner.stop()
            print(_color(f"\nError: {e}", RED))
        except KeyboardInterrupt:
            spinner.stop()
            print(_color("\n[interrupted]", DIM))

        print()
        if full_response:
            history.append({"role": "assistant", "content": full_response})


def cmd_ps(args: list[str]):
    """Show running model processes."""
    r = _api("GET", "/api/ps")
    procs = r.json().get("processes", [])
    if not procs:
        print(_color("No models currently running.", DIM))
        return

    print(f"\n{'NAME':<25} {'PORT':<8} {'UPTIME':<12} {'LAST USED'}")
    print("─" * 65)
    now = time.time()
    for p in procs:
        name = p["name"]
        port = p["port"]
        uptime = int(now - p.get("started_at", now))
        last = int(now - p.get("last_used", now))
        status = _color("● ALIVE", GREEN) if p.get("alive") else _color("✗ DEAD", RED)
        print(f"{name:<25} {port:<8} {_fmt_duration(uptime):<12} {_fmt_duration(last)} ago")
    print()


