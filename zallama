def main():
    if len(sys.argv) < 2 or sys.argv[1] in ("help", "--help", "-h"):
        print(BANNER)
        print(f"{BOLD}Usage:{RESET}  zallama <command> [args]\n")
        print(f"{BOLD}Commands:{RESET}")
        cmds = [
            ("serve", "Start the Zallama daemon"),
            ("list [--remote]", "List registered or remote preset models"),
            ("add <name> <file>", "Register a local .gguf model"),
            ("search <query>", "Search HuggingFace GGUF models"),
            ("pull <name>", "Pull a model from HF/unsloth"),
            ("remove <name>", "Remove a model from registry"),
            ("run <name>", "Interactive chat with a model"),
            ("ps", "Show running model processes"),
            ("load <name>", "Pre-load a model into memory"),
            ("unload <name>", "Stop a running model"),
            ("logs <name>", "Tail llama-server logs for a model"),
            ("health", "Show daemon health status"),
            ("version", "Show version"),
        ]
        for cmd, desc in cmds:
            print(f"  {_color(cmd, CYAN):<35}{DIM}{desc}{RESET}")
        print(f"\n{DIM}Daemon URL: {ZALLAMA_HOST}  (override with ZALLAMA_HOST env var){RESET}\n")
        return

    cmd = sys.argv[1]
    rest = sys.argv[2:]

    fn = COMMANDS.get(cmd)
    if fn is None:
        _err(f"Unknown command: '{cmd}'")
        _info("Run 'zallama help' for usage.")
        sys.exit(1)

    fn(rest)


if __name__ == "__main__":
