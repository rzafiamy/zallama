def _resolved_paths() -> dict:
    """Resolve every zallama path via the daemon's own config loader.

    Using load_config() (not a hand-rolled YAML read) means this is the single
    source of truth: `zallama paths` can never disagree with where the daemon
    actually reads/writes. Returns a dict of label -> Path/str, with the active
    config file (or None) under 'config'.
    """
    root = Path(__file__).resolve().parent
    sys.path.insert(0, str(root))
    from server.config import load_config, _find_config_file, resolve_binary

    cfg = load_config()
    models_dir = Path(cfg["zallama"]["models_dir"])
    try:
        binary = resolve_binary(cfg)
    except Exception:
        binary = "(not found — build with bash build-ggml-llama.cpp.sh)"
    return {
        "config.yaml": _find_config_file() or "(none — using built-in defaults)",
        "models_dir": models_dir,
        "registry.yaml": models_dir / "registry.yaml",
        "logs_dir": Path(cfg["zallama"]["logs_dir"]),
        "llama-server": binary,
    }


def cmd_paths(args: list[str]):
    """Show where zallama stores its files: zallama paths"""
    try:
        paths = _resolved_paths()
    except Exception as e:
        _err(f"Could not resolve paths: {e}")
        sys.exit(1)
    
    print(f"\n{BOLD}{F_BLUE} Zallama File Locations{RESET}")
    headers = ["COMPONENT", "PATH", "STATUS"]
    rows = []
    for label, value in paths.items():
        exists = isinstance(value, Path) and value.exists()
        status = _color("✓ exists", F_TEAL) if exists else (_color("—", F_DIM) if isinstance(value, Path) else _color("unknown", F_ORANGE))
        rows.append([label, str(value), status])
    _print_table(headers, rows)
    print()


def cmd_logs(args: list[str]):
    """Tail model logs: zallama logs <name>"""
    if not args:
        _err("Usage: zallama logs <model>"); sys.exit(1)
    name = args[0].replace(":", "_")
    # Resolve logs_dir via the daemon's config loader (single source of truth).
    try:
        logs_dir = Path(_resolved_paths()["logs_dir"])
    except Exception:
        logs_dir = Path.home() / ".zallama" / "logs"  # safe fallback
    log_file = logs_dir / f"{name}.log"
    if not log_file.exists():
        _err(f"No log file found: {log_file}")
        _info("Model may not have been run yet.")
        return
    try:
        os.execvp("tail", ["tail", "-f", "-n", "50", str(log_file)])
    except Exception:
        with open(log_file) as f:
            print(f.read())


def cmd_pull(args: list[str]):
    """Pull a model: zallama pull <name-or-hf-path> [--type text|asr|tts|rerank]

    --type sets the model's modality (default: text). Use it for raw HF paths
    whose repo name gives no hint, e.g.
        zallama pull owner/asr-repo/model.gguf --type asr
        zallama pull owner/reranker-repo/model.gguf --type rerank
    Shorthands and parakeet.cpp repos are detected automatically.
    """
    model = None
    mtype = None
    i = 0
    while i < len(args):
        a = args[i]
        if a in ("--type", "-t"):
            if i + 1 >= len(args):
                _err("--type requires a value (text|asr|tts|rerank)")
                sys.exit(1)
            mtype = args[i + 1]
            i += 2
        elif model is None:
            model = a
            i += 1
        else:
            i += 1

    if not model:
        _err("Usage: zallama pull <model-name-or-hf-path> [--type text|asr|tts|rerank]")
        _print_remote_presets()
        sys.exit(1)

    payload = {"model": model}
    if mtype:
        payload["type"] = mtype
    r = _api("POST", "/api/models/pull", payload)
    if r.status_code != 200:
        _err(f"Failed to start download: {r.json().get('detail', r.text)}")
        sys.exit(1)
    
    resp_data = r.json()
    model = resp_data.get("model", model)
    print(_color(f"⏳ Initiating pull for '{model}'...", F_BLUE))
    
    last_status = None
    while True:
        try:
            r = _api("GET", "/api/models/pull/status")
            downloads = r.json().get("downloads", [])
            task = next((t for t in downloads if t["model"] == model), None)
            
            if not task:
                time.sleep(0.5)
                continue
                
            status = task["status"]
            if status != last_status:
                last_status = status
                print(_color(f"\nStatus: {status.upper()}", F_ORANGE))
                
            if status == "completed":
                print()
                _ok(f"Successfully pulled and registered model '{model}'")
                break
            elif status == "failed":
                print()
                _err(f"Download failed: {task['error']}")
                sys.exit(1)
            elif status == "downloading":
                total = task["total_bytes"]
                completed = task["completed_bytes"]
                percent = task["percent"]
                speed = task.get("speed", 0.0)
                eta = task.get("eta", 0.0)
                
                bar_width = 25
                filled = int(percent / 100 * bar_width)
                bar = _color("█" * filled, F_BLUE) + _color("░" * (bar_width - filled), F_DIM)
                
                speed_str = f"{speed / 1024 / 1024:.2f} MB/s" if speed > 1024*1024 else f"{speed / 1024:.2f} KB/s"
                size_str = f"{completed / 1024 / 1024 / 1024:.2f} GB / {total / 1024 / 1024 / 1024:.2f} GB"
                eta_str = f"ETA: {int(eta)}s" if eta > 0 else "ETA: unknown"
                
                sys.stdout.write(f"\r  {bar}  {BOLD}{F_BLUE}{percent:.1f}%{RESET} ({size_str}) • {F_TEAL}{speed_str}{RESET} • {F_DIM}{eta_str}{RESET}")
                sys.stdout.flush()
                
            time.sleep(0.5)
        except (KeyboardInterrupt, SystemExit):
            print("\n" + _color("Download continuing in background daemon.", F_DIM))
            break


def cmd_search(args: list[str]):
    """Search HuggingFace GGUF models: zallama search <query>"""
    if not args:
        _err("Usage: zallama search <query-or-repo-id>")
        _info("Example: zallama search deepseek")
        _info("Example: zallama search unsloth/DeepSeek-R1-Distill-Llama-8B-GGUF")
        sys.exit(1)
        
    query = args[0]
    from urllib.parse import quote
    encoded = quote(query)
    
    r = _api("GET", f"/api/models/search?q={encoded}")
    if r.status_code != 200:
        _err(f"Search failed: {r.json().get('detail', r.text)}")
        sys.exit(1)
        
    data = r.json()
    resp_type = data.get("type")
    
    if resp_type == "repo_list":
        results = data.get("results", [])
        if not results:
            print(_color("No GGUF models found matching query.", F_DIM))
            return
            
        print(f"\n{BOLD}{F_BLUE} HuggingFace GGUF Repositories matching '{query}'{RESET}")
        headers = ["REPOSITORY ID", "DOWNLOADS", "LIKES"]
        rows = []
        for repo in results:
            rep_id = repo["id"]
            dls = repo["downloads"]
            likes = repo["likes"]
            
            dls_str = f"{dls:,}" if dls < 1000 else (f"{dls/1000:.1f}k" if dls < 1e6 else f"{dls/1e6:.1f}M")
            likes_str = f"{likes:,}"
            
            rows.append([_color(rep_id, F_TEAL + BOLD), dls_str, likes_str])
        _print_table(headers, rows)
        print(f"\n{F_DIM}  To view files in a repo: {RESET}{BOLD}zallama search <repository_id>{RESET}")
        print(f"{F_DIM}  To pull a model:         {RESET}{BOLD}zallama pull <repository_id>/<filename.gguf>{RESET}\n")
        
    elif resp_type == "file_list":
        repo_id = data.get("repo")
        files = data.get("files", [])
        dls = data.get("downloads", 0)
        likes = data.get("likes", 0)
        
        if not files:
            print(_color(f"No GGUF files found in repository '{repo_id}'.", F_DIM))
            return
            
        print(f"\n{BOLD}{F_BLUE} GGUF Files in '{repo_id}'{RESET}  {F_DIM}(Downloads: {dls:,} • Likes: {likes:,}){RESET}")
        headers = ["FILE NAME"]
        rows = [[f] for f in files]
        _print_table(headers, rows)
        
        suggested_file = files[0]
        # suggest a reasonable Q4_K_M or Q4_0 file if possible
        for f in files:
            if "q4_k_m" in f.lower() or "q4_0" in f.lower() or "q4_1" in f.lower():
                suggested_file = f
                break
        print(f"\n{F_DIM}  To pull this model: {RESET}{BOLD}zallama pull {repo_id}/{suggested_file}{RESET}\n")


