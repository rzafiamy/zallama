def _print_remote_presets():
    try:
        r = _api("GET", "/api/models/shorthands")
        shorthands = r.json().get("shorthands", {})
        print(f"\n{BOLD}{CYAN}Available Remote Preset Models (HuggingFace / Unsloth):{RESET}")
        print(f"{'NAME':<22} {'HF REPOSITORY & FILENAME':<55} {'DESCRIPTION'}")
        print("─" * 110)
        for name, info in shorthands.items():
            repo_file = f"{info['repo']}/{info['file']}"
            if len(repo_file) > 52:
                repo_file = repo_file[:49] + "..."
            desc = info.get("description", "")
            colored_name = _color(name, GREEN)
            padding = 22 - len(name)
            if padding < 0: padding = 0
            print(f"{colored_name}{' ' * padding} {repo_file:<55} {desc}")
        print(f"\n{DIM}To pull a model: zallama pull <name_or_custom_hf_path>{RESET}\n")
    except Exception as e:
        _err(f"Could not retrieve remote presets: {e}")


def cmd_list(args: list[str]):
    """List all registered models."""
    if args and args[0] in ("--remote", "-r", "remote"):
        _print_remote_presets()
        return

    r = _api("GET", "/api/models")
    data = r.json()
    models = data.get("models", [])

    if not models:
        print(_color("No models registered yet.", DIM))
        _info("Add a model with: zallama add <name> <path-to.gguf>")
        _info("Or pull a remote model: zallama pull <name>")
        return

    # Header
    print(f"\n{'NAME':<25} {'STATUS':<12} {'SIZE':<10} {'DESCRIPTION'}")
    print("─" * 75)
    for m in models:
        name = m["name"]
        status = _color("● RUNNING", GREEN) if m["running"] else _color("○ stopped", DIM)
        size = m.get("file_size", 0)
        size_str = f"{size / 1e9:.1f}GB" if size > 0 else "?"
        file_ok = m.get("file_ok", False)
        if not file_ok:
            size_str = _color("FILE MISSING", RED)
        desc = m.get("description", "")[:40]
        print(f"{name:<25} {status:<22} {size_str:<10} {desc}")
    print()


def cmd_add(args: list[str]):
    """Register a model: zallama add <name> <file>"""
    if len(args) < 2:
        _err("Usage: zallama add <name> <path-to-model.gguf> [description]")
        sys.exit(1)
    name, file_path = args[0], args[1]
    desc = " ".join(args[2:]) if len(args) > 2 else ""
    abs_path = str(Path(file_path).expanduser().resolve())
    r = _api("POST", "/api/models/add", {"name": name, "file": abs_path, "description": desc})
    if r.status_code == 200:
        _ok(f"Model '{name}' registered → {abs_path}")


def cmd_set(args: list[str]):
    """Set model parameters: zallama set <name> <key>=<value> [<key>=<value> ...]"""
    if len(args) < 2:
        _err("Usage: zallama set <model-name> <key>=<value> [<key>=<value> ...]")
        _info("Examples:")
        _info("  zallama set qwen3.5-4b-q4_k_m reasoning=false ctx_size=8192")
        _info("  zallama set llama3.2:1b n_gpu_layers=99")
        sys.exit(1)

    model_name = args[0]
    kv_args = args[1:]

    r = _api("GET", "/api/models")
    if r.status_code != 200:
        _err(f"Failed to fetch models list: {r.text}")
        sys.exit(1)

    models = r.json().get("models", [])
    model_entry = None
    for m in models:
        if m["name"] == model_name or model_name in m.get("aliases", []):
            model_entry = m
            break

    if not model_entry:
        _err(f"Model '{model_name}' not found in registry. Add it first using: zallama add")
        sys.exit(1)

    params = model_entry.get("params", {}).copy()
    for kv in kv_args:
        if "=" not in kv:
            _err(f"Invalid argument format: '{kv}'. Expected format: key=value")
            sys.exit(1)
        key, val = kv.split("=", 1)
        key = key.strip()
        val = val.strip()

        # Convert val to appropriate type
        if val.lower() == "true":
            parsed_val = True
        elif val.lower() == "false":
            parsed_val = False
        elif val.lower() in ("none", "null"):
            parsed_val = None
        else:
            try:
                parsed_val = int(val)
            except ValueError:
                try:
                    parsed_val = float(val)
                except ValueError:
                    parsed_val = val

        if parsed_val is None:
            params.pop(key, None)
        else:
            params[key] = parsed_val

    # Unload model first if it's running so the parameters apply immediately on next run
    if model_entry.get("running"):
        _api("POST", f"/api/models/{model_entry['name']}/unload")

    payload = {
        "name": model_entry["name"],
        "file": model_entry["file"],
        "description": model_entry["description"],
        "aliases": model_entry["aliases"],
        "params": params,
        # Preserve non-text modality / backend / extra artifacts (e.g. vision
        # mmproj) so a `set` doesn't silently reset them to defaults.
        "modality": model_entry.get("modality", "text"),
        "backend": model_entry.get("backend", "llama-server"),
        "artifacts": model_entry.get("artifacts", {}),
        "mem_gb": model_entry.get("mem_gb", 0),
    }

    r = _api("POST", "/api/models/add", payload)
    if r.status_code == 200:
        _ok(f"Updated parameters for '{model_entry['name']}' to: {params}")
    else:
        _err(f"Failed to update model parameters: {r.json().get('detail', r.text)}")


def cmd_remove(args: list[str]):
