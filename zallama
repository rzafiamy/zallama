def _flatten_cfg(cfg: dict, prefix: str = "") -> list[tuple[str, object]]:
    """Flatten a nested config dict into [(dotted.key, value), ...] in order.

    default_params is kept as a single node (rendered as a compact dict) rather
    than exploded, because those are per-model-overridable defaults, not
    top-level daemon settings.
    """
    out: list[tuple[str, object]] = []
    for key, val in cfg.items():
        dotted = f"{prefix}{key}"
        if isinstance(val, dict) and dotted != "llama_server.default_params":
            out.extend(_flatten_cfg(val, prefix=f"{dotted}."))
        else:
            out.append((dotted, val))
    return out


def cmd_config(args: list[str]):
    """Show the effective merged configuration and every available key.

    Resolves config through the daemon's own load_config() (the single source of
    truth, same as `zallama paths`), so it shows exactly what the daemon uses —
    defaults merged with config.yaml and env overrides — and works even when the
    daemon is down. Prints only; to change a value, edit config.yaml and restart.
    """
    root = Path(__file__).resolve().parent
    sys.path.insert(0, str(root))
    try:
        from server.config import load_config, _find_config_file
        cfg = load_config()
        config_file = _find_config_file()
    except Exception as e:
        _err(f"Could not load configuration: {e}")
        sys.exit(1)

    src = str(config_file) if config_file else "(none — using built-in defaults)"
    print(f"\n{BOLD}{F_BLUE} Effective Zallama Configuration{RESET}")
    print(f"{F_DIM}  Source: {src}{RESET}")

    rows = []
    for dotted, val in _flatten_cfg(cfg):
        if dotted == "llama_server.default_params" and isinstance(val, dict):
            shown = ", ".join(f"{k}={v}" for k, v in val.items())
        elif val == "" or val is None:
            shown = _color("(empty)", F_DIM)
        else:
            shown = str(val)
        desc = _CONFIG_KEY_HELP.get(dotted, "")
        rows.append([_color(dotted, F_TEAL), shown, _color(desc, F_DIM)])
    _print_table(["KEY", "VALUE", "DESCRIPTION"], rows)

    print(f"\n{F_DIM}  To change a value: edit {src if config_file else '~/.zallama/config.yaml'} "
          f"and restart the daemon.{RESET}")
    print(f"{F_DIM}  Per-model overrides of default_params: {RESET}{BOLD}zallama set <model> <key>=<value>{RESET}\n")


import threading

class Spinner:
    def __init__(self, message="Thinking..."):
        self.message = message
        self.running = False
        self.thread = None

    def _spin(self):
        chars = ["⠋", "⠙", "⠹", "⠸", "⠼", "⠴", "⠦", "⠧", "⠇", "⠏"]
        idx = 0
        while self.running:
            sys.stdout.write(f"\r{_color(chars[idx], F_BLUE + BOLD)} {F_DIM}{self.message}{RESET}")
            sys.stdout.flush()
            idx = (idx + 1) % len(chars)
            time.sleep(0.08)
        sys.stdout.write("\r" + " " * (len(self.message) + 15) + "\r")
        sys.stdout.flush()

    def start(self):
        self.running = True
        self.thread = threading.Thread(target=self._spin, daemon=True)
        self.thread.start()

    def stop(self):
        if self.running:
            self.running = False
            if self.thread:
                self.thread.join()

def cmd_run(args: list[str]):
    """Interactive chat: zallama run <model>"""
    if not args:
        _err("Usage: zallama run <model-name>")
        sys.exit(1)
    model = args[0]

    # Fetch model details to check modality
    r_models = _api("GET", "/api/models")
    if r_models.status_code == 200:
        models_info = r_models.json().get("models", [])
        model_entry = next((m for m in models_info if m["name"] == model), None)
        if model_entry and model_entry.get("modality") == "asr":
            _err(f"Model '{model}' is an ASR (Speech-to-Text) model and cannot be used in interactive chat.")
            _info("To transcribe audio with this model, use:")
            _info(f"  zallama transcribe {model} <audio-file.wav>")
            sys.exit(1)

    # Width-aware Fluent 2 style banner header. The inner width adapts to the
    # terminal (capped) so a long model name never overflows or misaligns the box.
    inner = min(_term_width() - 4, 64)
    bar = "─" * inner

    def _banner_row(text: str, color: str) -> str:
        pad = " " * max(0, inner - _visible_len(text))
        return f"{_color('│', F_BLUE)} {color}{text}{pad}{RESET} {_color('│', F_BLUE)}"

    def _trunc(s: str) -> str:
        return s if len(s) <= inner else s[: inner - 1] + "…"

    print(_color(f"\n╭{bar}╮", F_BLUE))
    print(_banner_row("ZALLAMA INTERACTIVE CHAT", BOLD + F_WHITE))
    print(_banner_row(_trunc(f"Model: {model}"), F_GRAY))
    print(_banner_row(_trunc("Type a message and press Enter. /exit to quit, /clear to reset."), F_DIM))
    print(_color(f"╰{bar}╯", F_BLUE))

    # First, ensure the model is loaded (may take a moment)
    print(_color(f"⏳ Loading model '{model}'...", F_ORANGE), end="", flush=True)
    r = _api("POST", f"/api/models/{model}/load")
    if r.status_code != 200:
        print()
        _err(f"Failed to load model: {r.json().get('detail', r.text)}")
        sys.exit(1)
    print(_color(" Ready!", F_TEAL))

    history = []

    while True:
        try:
            user_input = input(_color("\nUser › ", F_BLUE + BOLD)).strip()
        except (KeyboardInterrupt, EOFError):
            print("\n" + _color("Goodbye! 👋", F_DIM))
            break

        if not user_input:
            continue
        if user_input.lower() in ("/exit", "/quit", "exit", "quit"):
            print(_color("Goodbye! 👋", F_DIM))
            break
        if user_input == "/clear":
            history = []
            print(_color("History cleared.", F_DIM))
            continue

        history.append({"role": "user", "content": user_input})

        payload = {"model": model, "messages": history, "stream": True}
        spinner = Spinner("Thinking...")
        spinner.start()

        # Stream reasoning live (it's transient "thinking"), but accumulate the
        # answer content and render it beautified once complete — markdown can't
        # be cleanly formatted token-by-token, so we draft, then re-render.
        beautify = sys.stdout.isatty()
        reasoning_text = ""
        content_text = ""
        try:
            r = requests.post(
                f"{ZALLAMA_HOST}/v1/chat/completions",
                json=payload,
                stream=True,
                timeout=None,
            )

            if r.status_code != 200:
                spinner.stop()
                try:
                    err_msg = r.json().get("detail", r.text)
                except Exception:
                    err_msg = r.text
                print(_color(f"\nError: {err_msg}", F_RED))
                continue

            buffer = b""
            spinner_stopped = False
            in_reasoning = False
            content_started = False

            done = False
            for chunk in r.iter_content(chunk_size=None):
                buffer += chunk
                while b"\n" in buffer:
                    line_bytes, buffer = buffer.split(b"\n", 1)
                    line_str = line_bytes.decode("utf-8", errors="ignore").strip()
                    if not line_str:
                        continue
                    text = line_str[6:] if line_str.startswith("data: ") else line_str

                    if text == "[DONE]":
                        done = True
                        break

                    try:
                        chunk_json = json.loads(text)
                        delta = chunk_json["choices"][0]["delta"]

                        reasoning_content = delta.get("reasoning_content", "")
                        delta_content = delta.get("content", "")

                        if reasoning_content:
                            if not spinner_stopped:
                                spinner.stop(); spinner_stopped = True
                            if not in_reasoning:
                                in_reasoning = True
                                print(f"\n{BOLD}{F_PURPLE}🧠 Thinking Process:{RESET}")
                            print(_color(reasoning_content, F_DIM), end="", flush=True)
                            reasoning_text += reasoning_content
                        elif delta_content:
                            # Keep the spinner spinning while drafting the answer
                            # so the user sees progress; the frame prints at the end.
                            if in_reasoning:
                                in_reasoning = False
                                print("\n")
                            if not content_started:
                                content_started = True
                                if not beautify and not spinner_stopped:
                                    spinner.stop(); spinner_stopped = True
                                if not beautify:
                                    print(f"\n{BOLD}{F_TEAL}🦙 Assistant:{RESET}")
                            content_text += delta_content
                            if not beautify:
                                print(delta_content, end="", flush=True)
                    except Exception:
                        pass
                if done:
                    break

            if not spinner_stopped:
                spinner.stop()

            if beautify and content_text:
                _print_framed(content_text, "🦙 Assistant", F_TEAL)
            elif not beautify:
                print()

        except Exception as e:
            spinner.stop()
            print(_color(f"\nError: {e}", F_RED))
        except KeyboardInterrupt:
            spinner.stop()
            print(_color("\n[interrupted]", F_DIM))

        print()
        full_response = reasoning_text + content_text
        if content_text:
            history.append({"role": "assistant", "content": content_text})


def cmd_ps(args: list[str]):
    """Show running model processes."""
    r = _api("GET", "/api/ps")
    data = r.json()
    procs = data.get("processes", [])
    mem = data.get("memory", {})
    if not procs:
        print(_color("\nNo models currently running.", F_DIM))
        _print_mem_status(mem)
        return

    print(f"\n{BOLD}{F_BLUE} Running Model Processes{RESET}")
    headers = ["MODEL", "PORT", "EST. MEM", "VRAM (real)", "UPTIME", "LAST USED"]
    rows = []
    now = time.time()
    for p in procs:
        name = p["name"]
        port = str(p["port"])
        mem_gb = p.get("mem_gb", 0)
        mem_str = f"{mem_gb:.1f} GB" if mem_gb else "?"
        vram = p.get("vram_gb")
        vram_str = f"{vram:.1f} GB" if vram else _color("—", F_DIM)
        uptime = int(now - p.get("started_at", now))
        last = int(now - p.get("last_used", now))
        rows.append([
            _color(name, F_TEAL + BOLD),
            _color(port, F_BLUE),
            mem_str,
            vram_str,
            _fmt_duration(uptime),
            f"{_fmt_duration(last)} ago"
        ])
    _print_table(headers, rows)
    _print_mem_status(mem)
    print()


def _print_mem_status(mem: dict):
    if not mem:
        return
    budget = mem.get("budget_gb") or 0
    loaded = mem.get("loaded_gb", 0)
    count = mem.get("loaded_count", 0)
    vram = mem.get("vram_used_gb")
    vram_str = f"  •  {vram:.1f} GB real VRAM" if vram else ""
    if budget > 0:
        head = mem.get("headroom_gb", 0)
        print(_color(f"\n  📊 Memory usage: {loaded:.1f} GB / {budget:.1f} GB est.  •  {head:.1f} GB free{vram_str}  •  {count} model(s) loaded", F_BLUE))
    elif count:
        print(_color(f"\n  📊 Memory usage: {loaded:.1f} GB est. loaded across {count} model(s){vram_str}", F_BLUE))


