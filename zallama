def cmd_serve(args: list[str]):
    """Start the Zallama daemon (foreground)."""
    print(_color("🦙 Starting Zallama daemon...", CYAN + BOLD))
    root = Path(__file__).parent
    sys.path.insert(0, str(root))
    try:
        from server.main import main
        main()
    except ImportError as e:
        _err(f"Import error: {e}")
        _info("Ensure dependencies are installed: pip install -r requirements.txt")
        sys.exit(1)


def _print_remote_presets():
    try:
        r = _api("GET", "/api/models/shorthands")
        shorthands = r.json().get("shorthands", {})
        print(f"\n{BOLD}{F_BLUE} Available Remote Presets (HuggingFace / Unsloth){RESET}")
        headers = ["PRESET", "HF REPOSITORY / FILENAME", "DESCRIPTION"]
        rows = []
        for name, info in shorthands.items():
            repo_file = f"{info['repo']}/{info['file']}"
            if len(repo_file) > 55:
                repo_file = repo_file[:52] + "..."
            desc = info.get("description", "")
            rows.append([_color(name, F_TEAL + BOLD), repo_file, desc])
        _print_table(headers, rows)
        print(f"\n{F_DIM}  To pull a model: {RESET}{BOLD}zallama pull <preset_name_or_custom_hf_path>{RESET}\n")
    except Exception as e:
        _err(f"Could not retrieve remote presets: {e}")


def cmd_list(args: list[str]):
    """List all registered models."""
    if args and args[0] in ("--remote", "-r", "remote"):
        _print_remote_presets()
        return

    r = _api("GET", "/api/models")
    data = r.json()
    models = data.get("models", [])

    if not models:
        print(_color("No models registered yet.", F_DIM))
        _info("Add a model with: zallama add <name> <path-to.gguf>")
        _info("Or pull a remote model: zallama pull <name>")
        return

    print(f"\n{BOLD}{F_BLUE} Registered Models{RESET}")
    headers = ["MODEL", "MODALITY", "ENGINE", "STATUS", "SIZE", "DESCRIPTION"]
    rows = []
    for m in models:
        name = m["name"]
        modality = m.get("modality", "text")
        backend = m.get("backend", "llama-server")
        status = _color("● RUNNING", F_TEAL) if m["running"] else _color("○ stopped", F_DIM)
        size = m.get("file_size", 0)
        size_str = f"{size / 1e9:.1f} GB" if size > 0 else "?"
        file_ok = m.get("file_ok", False)
        if not file_ok:
            size_str = _color("FILE MISSING", F_RED)
        desc = m.get("description", "")
        if len(desc) > 30:
            desc = desc[:27] + "..."
        rows.append([
            _color(name, F_BLUE + BOLD),
            _color(modality, F_GRAY),
            _color(backend, F_DIM),
            status,
            size_str,
            desc
        ])
    _print_table(headers, rows)
    print()


def cmd_add(args: list[str]):
    """Register a model: zallama add <name> <file> [--modality <val>] [--backend <val>]"""
    modality = "text"
    backend = "llama-server"
    
    filtered_args = []
    i = 0
    while i < len(args):
        if args[i] == "--modality" and i + 1 < len(args):
            modality = args[i+1]
            i += 2
        elif args[i] == "--backend" and i + 1 < len(args):
            backend = args[i+1]
            i += 2
        else:
            filtered_args.append(args[i])
            i += 1
            
    if len(filtered_args) < 2:
        _err("Usage: zallama add <name> <path-to-model.gguf> [description] [--modality <modality>] [--backend <backend>]")
        _info("Supported modalities: text, embedding, rerank, asr, tts, image")
        _info("Supported backends: llama-server, embedding-server, rerank-server, parakeet-server, kokoro-server")
        _info("Tip: set --modality only; the matching backend is auto-selected.")
        sys.exit(1)
        
    name, file_path = filtered_args[0], filtered_args[1]
    desc = " ".join(filtered_args[2:]) if len(filtered_args) > 2 else ""
    
    if modality == "text" and backend == "llama-server":
        if "parakeet" in file_path.lower() or "parakeet" in name.lower():
            modality = "asr"
            backend = "parakeet-server"
            
    abs_path = str(Path(file_path).expanduser().resolve())
    r = _api("POST", "/api/models/add", {
        "name": name, 
        "file": abs_path, 
        "description": desc,
        "modality": modality,
        "backend": backend
    })
    if r.status_code == 200:
        _ok(f"Model '{name}' registered ({modality} / {backend}) → {abs_path}")


def cmd_set(args: list[str]):
    """Set model parameters: zallama set <name> <key>=<value> [<key>=<value> ...]"""
    if len(args) < 2:
        _err("Usage: zallama set <model-name> <key>=<value> [<key>=<value> ...]")
        _info("Examples:")
        _info("  zallama set qwen3.5-4b-q4_k_m reasoning=false ctx_size=8192")
        _info("  zallama set llama3.2:1b n_gpu_layers=99")
        _info("  zallama set my-reranker modality=rerank    # backend auto-selected")
        _info("  zallama set my-embed modality=embedding    # serve /v1/embeddings")
        _info("Special keys: modality (text|embedding|rerank|asr|tts|image), backend.")
        sys.exit(1)

    model_name = args[0]
    kv_args = args[1:]

    r = _api("GET", "/api/models")
    if r.status_code != 200:
        _err(f"Failed to fetch models list: {r.text}")
        sys.exit(1)

    models = r.json().get("models", [])
    model_entry = None
    for m in models:
        if m["name"] == model_name or model_name in m.get("aliases", []):
            model_entry = m
            break

    if not model_entry:
        _err(f"Model '{model_name}' not found in registry. Add it first using: zallama add")
        sys.exit(1)

    params = model_entry.get("params", {}).copy()
    # modality / backend are entry-level fields, not llama-server params. Setting
    # `modality=rerank` reclassifies the model; the server then auto-resolves the
    # matching backend unless `backend=` is also given. Setting `backend=` alone
    # overrides just the engine. These are pulled out of the kv loop below.
    modality = model_entry.get("modality", "text")
    backend = model_entry.get("backend", "llama-server")
    backend_explicit = False

    for kv in kv_args:
        if "=" not in kv:
            _err(f"Invalid argument format: '{kv}'. Expected format: key=value")
            sys.exit(1)
        key, val = kv.split("=", 1)
        key = key.strip()
        val = val.strip()

        if key == "modality":
            modality = val.lower()
            continue
        if key == "backend":
            backend = val
            backend_explicit = True
            continue

        # Convert val to appropriate type
        if val.lower() == "true":
            parsed_val = True
        elif val.lower() == "false":
            parsed_val = False
        elif val.lower() in ("none", "null"):
            parsed_val = None
        else:
            try:
                parsed_val = int(val)
            except ValueError:
                try:
                    parsed_val = float(val)
                except ValueError:
                    parsed_val = val

        if parsed_val is None:
            params.pop(key, None)
        else:
            params[key] = parsed_val

    # If the modality changed but the backend wasn't set explicitly, let the
    # server pick the modality's default backend by sending the llama-server
    # default (text) / clearing a now-mismatched backend.
    if not backend_explicit and modality != model_entry.get("modality", "text"):
        backend = "llama-server"

    # Unload model first if it's running so the parameters apply immediately on next run
    if model_entry.get("running"):
        _api("POST", f"/api/models/{model_entry['name']}/unload")

    payload = {
        "name": model_entry["name"],
        "file": model_entry["file"],
        "description": model_entry["description"],
        "aliases": model_entry["aliases"],
        "params": params,
        # Preserve / update modality & backend (+ extra artifacts like a vision
        # mmproj) so a `set` doesn't silently reset them to defaults.
        "modality": modality,
        "backend": backend,
        "artifacts": model_entry.get("artifacts", {}),
        "mem_gb": model_entry.get("mem_gb", 0),
    }

    r = _api("POST", "/api/models/add", payload)
    if r.status_code == 200:
        _ok(f"Updated '{model_entry['name']}' "
            f"(modality={modality}, backend={backend}) params={params}")
    else:
        _err(f"Failed to update model: {r.json().get('detail', r.text)}")


def cmd_remove(args: list[str]):
    """Remove a model: zallama remove <name>"""
    if not args:
        _err("Usage: zallama remove <name>")
        sys.exit(1)
    name = args[0]
    r = _api("DELETE", f"/api/models/{name}")
    if r.status_code == 200:
        _ok(f"Model '{name}' removed from registry")
    else:
        _err(f"Failed: {r.json().get('detail', r.text)}")
        sys.exit(1)


# ---------------------------------------------------------------------------
# GGUF metadata reader (header-only; no deps)
# ---------------------------------------------------------------------------
def _read_gguf_metadata(path: Path) -> dict:
    """Parse the key/value metadata from a GGUF file header.

    Reads only the header (not the tensor data), so it is fast even on
    multi-GB files. Returns a flat {key: value} dict for the scalar string/int
    keys we need to size a KV-cache (block_count, attention.head_count[_kv],
    embedding_length, context_length). Supports GGUF v2/v3.
    """
    import struct

    # GGUF scalar type ids -> (struct format, size in bytes).
    _SCALAR = {
        0: ("B", 1), 1: ("b", 1), 2: ("H", 2), 3: ("h", 2),
        4: ("I", 4), 5: ("i", 4), 6: ("f", 4), 7: ("?", 1),
        10: ("Q", 8), 11: ("q", 8), 12: ("d", 8),
    }
    STRING, ARRAY = 8, 9

    with open(path, "rb") as f:
        magic = f.read(4)
        if magic != b"GGUF":
            raise ValueError(f"Not a GGUF file (bad magic): {path}")
        version = struct.unpack("<I", f.read(4))[0]
        # tensor_count (u64) then metadata_kv_count (u64) in v2/v3.
        _ = struct.unpack("<Q", f.read(8))[0]
        kv_count = struct.unpack("<Q", f.read(8))[0]

        def read_str() -> str:
            n = struct.unpack("<Q", f.read(8))[0]
            return f.read(n).decode("utf-8", "replace")

        def read_scalar(tid: int):
            fmt, size = _SCALAR[tid]
            return struct.unpack("<" + fmt, f.read(size))[0]

        def skip_value(tid: int):
            # Consume a value of the given type without keeping it (for arrays
            # and keys we don't care about), so the cursor stays aligned.
            if tid == STRING:
                read_str()
            elif tid == ARRAY:
                elem_tid = struct.unpack("<I", f.read(4))[0]
                count = struct.unpack("<Q", f.read(8))[0]
                for _ in range(count):
                    skip_value(elem_tid)
            else:
                read_scalar(tid)

        meta: dict = {}
        for _ in range(kv_count):
            key = read_str()
            tid = struct.unpack("<I", f.read(4))[0]
            if tid == STRING:
                meta[key] = read_str()
            elif tid == ARRAY:
                skip_value(ARRAY)  # arrays aren't needed for sizing
            else:
                meta[key] = read_scalar(tid)
        meta["_gguf_version"] = version
        return meta


def _gguf_arch_dims(meta: dict) -> dict | None:
    """Extract layer/head/embedding dims from GGUF metadata, arch-agnostic.

    Keys are namespaced by architecture (e.g. "llama.block_count"). We read the
    `general.architecture` value and look up that prefix. Returns None if the
    essential keys are missing (e.g. a non-text GGUF), letting the caller fall
    back to a size-based estimate.
    """
    arch = meta.get("general.architecture")
    if not arch:
        return None

    def g(suffix: str):
        return meta.get(f"{arch}.{suffix}")

    n_layer = g("block_count")
    n_embd = g("embedding_length")
    n_head = g("attention.head_count")
    # GQA: head_count_kv defaults to head_count when absent (full MHA).
    n_head_kv = g("attention.head_count_kv") or n_head
    train_ctx = g("context_length")
    if not (n_layer and n_embd and n_head and n_head_kv):
        return None
    head_dim = n_embd // n_head
    return {
        "arch": arch,
        "n_layer": int(n_layer),
        "n_embd": int(n_embd),
        "n_head": int(n_head),
        "n_head_kv": int(n_head_kv),
        "head_dim": int(head_dim),
        "train_ctx": int(train_ctx) if train_ctx else None,
    }


def _query_total_vram_gb() -> float | None:
    """Total VRAM (GB) of GPU 0 via nvidia-smi, or None if unavailable."""
    import shutil
    import subprocess

    if shutil.which("nvidia-smi") is None:
        return None
    try:
        out = subprocess.check_output(
            ["nvidia-smi", "--query-gpu=memory.total",
             "--format=csv,noheader,nounits"],
            text=True, timeout=5,
        )
    except Exception:
        return None
    first = out.strip().splitlines()
    if not first:
        return None
    try:
        return int(first[0].strip()) / 1024.0  # MiB -> GiB
    except ValueError:
        return None


def cmd_calibrate(args: list[str]):
    """Recommend max ctx_size + mem_gb for a model from your VRAM (dry-run).

    Usage: zallama calibrate <model>

    Queries total GPU VRAM, reads the model's GGUF architecture (layers, heads,
    GQA, head_dim), and computes the largest context window whose KV-cache still
    fits alongside the model weights and a compute reserve. Prints the
    recommendation and the exact `zallama set` command — it writes nothing.
    """
    if not args:
        _err("Usage: zallama calibrate <model>")
        _info("Recommends a max ctx_size + mem_gb from your VRAM. Changes nothing.")
        sys.exit(1)
    model_name = args[0]

    # 1. Locate the model entry (file path, size, current params).
    r = _api("GET", "/api/models")
    if r.status_code != 200:
        _err(f"Failed to fetch models: {r.text}"); sys.exit(1)
    entry = None
    for m in r.json().get("models", []):
        if m["name"] == model_name or model_name in m.get("aliases", []):
            entry = m
            break
    if not entry:
        _err(f"Model '{model_name}' not found in registry."); sys.exit(1)
    if entry.get("modality", "text") != "text":
        _err(f"Calibration targets text models; '{model_name}' is "
             f"'{entry.get('modality')}'. ctx_size sizing doesn't apply.")
        sys.exit(1)
    if not entry.get("file_ok"):
        _err(f"Model file is missing: {entry.get('file')}"); sys.exit(1)

    # 2. VRAM budget.
    total_vram = _query_total_vram_gb()
    if total_vram is None:
        _err("Could not query VRAM (no nvidia-smi or no NVIDIA GPU).")
        _info("Calibration currently supports NVIDIA GPUs only.")
        sys.exit(1)

    file_gb = entry.get("file_size", 0) / 1e9
    model_path = Path(entry["file"])

    # 3. GGUF architecture.
    try:
        meta = _read_gguf_metadata(model_path)
        dims = _gguf_arch_dims(meta)
    except Exception as e:
        dims = None
        _info(f"Could not read GGUF metadata ({e}); using a size-only estimate.")

    # 4. Budgeting. Leave a slice of VRAM for the OS/desktop + llama.cpp's
    #    compute buffers (activations, graph). 88% usable is a safe default on
    #    an 8GB laptop GPU where a few hundred MB are always taken by the DE.
    usable = total_vram * 0.88
    # Weights resident in VRAM ~= on-disk GGUF size (n_gpu_layers=99 => all on
    # GPU). A small compute reserve scales with model size.
    compute_reserve = max(0.4, file_gb * 0.10)
    kv_budget_gb = usable - file_gb - compute_reserve

    cur_ctx = entry.get("params", {}).get("ctx_size", 4096)

    if dims and kv_budget_gb > 0:
        # KV-cache bytes per token = 2 (K+V) * n_layer * n_head_kv * head_dim *
        # bytes_per_elem. llama.cpp defaults to f16 KV (2 bytes).
        bytes_per_tok = 2 * dims["n_layer"] * dims["n_head_kv"] * dims["head_dim"] * 2
        max_ctx = int((kv_budget_gb * 1e9) / bytes_per_tok)
        # Round down to a multiple of 1024 and clamp to the model's trained ctx.
        max_ctx = (max_ctx // 1024) * 1024
        if dims["train_ctx"]:
            max_ctx = min(max_ctx, dims["train_ctx"])
        max_ctx = max(max_ctx, 1024)
        kv_at_ctx = bytes_per_tok * max_ctx / 1e9
        est_mem_gb = round(file_gb + kv_at_ctx + compute_reserve, 1)
        method = "GGUF KV-cache model"
    else:
        # Fallback: no arch dims — recommend a conservative ctx and estimate
        # mem from file size only.
        max_ctx = 4096 if file_gb < usable * 0.6 else 2048
        est_mem_gb = round(file_gb * 1.2 + compute_reserve, 1)
        method = "size-only estimate (GGUF dims unavailable)"

    # 5. Report. Print only — never write.
    print(f"\n{BOLD}{F_BLUE} Calibration for '{model_name}'{RESET}")
    rows = [
        ["GPU VRAM (total)", f"{total_vram:.1f} GB"],
        ["Usable (88%)", f"{usable:.1f} GB"],
        ["Model weights (file)", f"{file_gb:.1f} GB"],
        ["Compute reserve", f"{compute_reserve:.1f} GB"],
        ["KV-cache budget", f"{max(kv_budget_gb, 0):.1f} GB"],
    ]
    if dims:
        rows.append(["Architecture",
                     f"{dims['arch']} • {dims['n_layer']}L • "
                     f"{dims['n_head_kv']} KV-heads • head_dim {dims['head_dim']}"])
        if dims["train_ctx"]:
            rows.append(["Trained ctx", f"{dims['train_ctx']}"])
    rows += [
        ["Current ctx_size", str(cur_ctx)],
        [_color("→ Recommended ctx_size", F_TEAL + BOLD),
         _color(str(max_ctx), F_TEAL + BOLD)],
        [_color("→ Recommended mem_gb", F_TEAL + BOLD),
         _color(str(est_mem_gb), F_TEAL + BOLD)],
    ]
    _print_table(["FIELD", "VALUE"], rows)
    print(f"\n{F_DIM}  Method: {method}. KV-cache assumes f16 ("
          f"halve mem with a quantized KV cache).{RESET}")

    if kv_budget_gb <= 0:
        _err(f"Weights ({file_gb:.1f} GB) + reserve exceed usable VRAM "
             f"({usable:.1f} GB). This model may not fit fully on GPU; "
             f"lower n_gpu_layers or use a smaller quant.")

    print(f"\n{BOLD}  To apply (dry-run only — nothing was changed):{RESET}")
    print(f"    {_color(f'zallama set {model_name} ctx_size={max_ctx} mem_gb={est_mem_gb}', CYAN)}")
    print(f"\n{F_DIM}  Then `zallama reload {model_name}` (or it applies on next load).{RESET}\n")


def cmd_show(args: list[str]):
    """Show a single model's full configuration: zallama show <model>

    `zallama list` is a summary table; this prints *everything* the registry
    holds for one model — resolved file path, every param (merged view of the
    effective launch params), aliases, artifacts, declared mem_gb, and live
    status — so there is no longer a setting you cannot see from the CLI.
    """
    if not args:
        _err("Usage: zallama show <model>")
        sys.exit(1)
    model_name = args[0]

    r = _api("GET", "/api/models")
    if r.status_code != 200:
        _err(f"Failed to fetch models: {r.text}"); sys.exit(1)
    entry = None
    for m in r.json().get("models", []):
        if m["name"] == model_name or model_name in m.get("aliases", []):
            entry = m
            break
    if not entry:
        _err(f"Model '{model_name}' not found in registry."); sys.exit(1)

    size = entry.get("file_size", 0)
    size_str = f"{size / 1e9:.2f} GB" if size else "?"
    status = _color("● RUNNING", F_TEAL) if entry.get("running") else _color("○ stopped", F_DIM)
    if entry.get("running") and entry.get("port"):
        status += _color(f"  (port {entry['port']})", F_DIM)

    print(f"\n{BOLD}{F_BLUE} Model: {entry['name']}{RESET}")
    rows = [
        ["Status", status],
        ["Modality", entry.get("modality", "text")],
        ["Backend", entry.get("backend", "llama-server")],
        ["File", str(entry.get("file", "?"))
            + ("" if entry.get("file_ok") else _color("  ✗ MISSING", F_RED))],
        ["Size", size_str],
        ["Declared mem_gb", str(entry.get("mem_gb", 0) or "(inferred)")],
        ["Aliases", ", ".join(entry.get("aliases", [])) or _color("—", F_DIM)],
        ["Description", entry.get("description", "") or _color("—", F_DIM)],
    ]
    artifacts = entry.get("artifacts") or {}
    if artifacts:
        rows.append(["Artifacts", ", ".join(f"{k}={v}" for k, v in artifacts.items())])
    _print_table(["FIELD", "VALUE"], rows)

    # Params: the per-model overrides. Show them explicitly so `set` targets are
    # discoverable. Empty means "uses the server defaults" (see `zallama config`).
    params = entry.get("params") or {}
    print(f"\n{BOLD}  Parameters{RESET} {F_DIM}(overrides; unset keys use server defaults — see `zallama config`){RESET}")
    if params:
        prows = [[_color(k, F_TEAL), str(v)] for k, v in sorted(params.items())]
        _print_table(["KEY", "VALUE"], prows)
    else:
        print(_color("    (none — this model uses the server default_params)", F_DIM))
    print(f"\n{F_DIM}  Change a param: {RESET}{BOLD}zallama set {entry['name']} <key>=<value>{RESET}\n")


