def cmd_serve(args: list[str]):
    """Start the Zallama daemon (foreground)."""
    print(_color("🦙 Starting Zallama daemon...", CYAN + BOLD))
    root = Path(__file__).parent
    sys.path.insert(0, str(root))
    try:
        from server.main import main
        main()
    except ImportError as e:
        _err(f"Import error: {e}")
        _info("Ensure dependencies are installed: pip install -r requirements.txt")
        sys.exit(1)


def _print_remote_presets():
    try:
        r = _api("GET", "/api/models/shorthands")
        shorthands = r.json().get("shorthands", {})
        print(f"\n{BOLD}{F_BLUE} Available Remote Presets (HuggingFace / Unsloth){RESET}")
        headers = ["PRESET", "HF REPOSITORY / FILENAME", "DESCRIPTION"]
        rows = []
        for name, info in shorthands.items():
            repo_file = f"{info['repo']}/{info['file']}"
            if len(repo_file) > 55:
                repo_file = repo_file[:52] + "..."
            desc = info.get("description", "")
            rows.append([_color(name, F_TEAL + BOLD), repo_file, desc])
        _print_table(headers, rows)
        print(f"\n{F_DIM}  To pull a model: {RESET}{BOLD}zallama pull <preset_name_or_custom_hf_path>{RESET}\n")
    except Exception as e:
        _err(f"Could not retrieve remote presets: {e}")


def cmd_list(args: list[str]):
    """List all registered models."""
    if args and args[0] in ("--remote", "-r", "remote"):
        _print_remote_presets()
        return

    r = _api("GET", "/api/models")
    data = r.json()
    models = data.get("models", [])

    if not models:
        print(_color("No models registered yet.", F_DIM))
        _info("Add a model with: zallama add <name> <path-to.gguf>")
        _info("Or pull a remote model: zallama pull <name>")
        return

    print(f"\n{BOLD}{F_BLUE} Registered Models{RESET}")
    headers = ["MODEL", "MODALITY", "ENGINE", "STATUS", "SIZE", "DESCRIPTION"]
    rows = []
    for m in models:
        name = m["name"]
        modality = m.get("modality", "text")
        backend = m.get("backend", "llama-server")
        status = _color("● RUNNING", F_TEAL) if m["running"] else _color("○ stopped", F_DIM)
        size = m.get("file_size", 0)
        size_str = f"{size / 1e9:.1f} GB" if size > 0 else "?"
        file_ok = m.get("file_ok", False)
        if not file_ok:
            size_str = _color("FILE MISSING", F_RED)
        desc = m.get("description", "")
        if len(desc) > 30:
            desc = desc[:27] + "..."
        rows.append([
            _color(name, F_BLUE + BOLD),
            _color(modality, F_GRAY),
            _color(backend, F_DIM),
            status,
            size_str,
            desc
        ])
    _print_table(headers, rows)
    print()


def cmd_add(args: list[str]):
    """Register a model: zallama add <name> <file> [--modality <val>] [--backend <val>]"""
    modality = "text"
    backend = "llama-server"
    
    filtered_args = []
    i = 0
    while i < len(args):
        if args[i] == "--modality" and i + 1 < len(args):
            modality = args[i+1]
            i += 2
        elif args[i] == "--backend" and i + 1 < len(args):
            backend = args[i+1]
            i += 2
        else:
            filtered_args.append(args[i])
            i += 1
            
    if len(filtered_args) < 2:
        _err("Usage: zallama add <name> <path-to-model.gguf> [description] [--modality <modality>] [--backend <backend>]")
        _info("Supported modalities: text, asr, tts, image")
        _info("Supported backends: llama-server, parakeet-server")
        sys.exit(1)
        
    name, file_path = filtered_args[0], filtered_args[1]
    desc = " ".join(filtered_args[2:]) if len(filtered_args) > 2 else ""
    
    if modality == "text" and backend == "llama-server":
        if "parakeet" in file_path.lower() or "parakeet" in name.lower():
            modality = "asr"
            backend = "parakeet-server"
            
    abs_path = str(Path(file_path).expanduser().resolve())
    r = _api("POST", "/api/models/add", {
        "name": name, 
        "file": abs_path, 
        "description": desc,
        "modality": modality,
        "backend": backend
    })
    if r.status_code == 200:
        _ok(f"Model '{name}' registered ({modality} / {backend}) → {abs_path}")


def cmd_set(args: list[str]):
    """Set model parameters: zallama set <name> <key>=<value> [<key>=<value> ...]"""
    if len(args) < 2:
        _err("Usage: zallama set <model-name> <key>=<value> [<key>=<value> ...]")
        _info("Examples:")
        _info("  zallama set qwen3.5-4b-q4_k_m reasoning=false ctx_size=8192")
        _info("  zallama set llama3.2:1b n_gpu_layers=99")
        sys.exit(1)

    model_name = args[0]
    kv_args = args[1:]

    r = _api("GET", "/api/models")
    if r.status_code != 200:
        _err(f"Failed to fetch models list: {r.text}")
        sys.exit(1)

    models = r.json().get("models", [])
    model_entry = None
    for m in models:
        if m["name"] == model_name or model_name in m.get("aliases", []):
            model_entry = m
            break

    if not model_entry:
        _err(f"Model '{model_name}' not found in registry. Add it first using: zallama add")
        sys.exit(1)

    params = model_entry.get("params", {}).copy()
    for kv in kv_args:
        if "=" not in kv:
            _err(f"Invalid argument format: '{kv}'. Expected format: key=value")
            sys.exit(1)
        key, val = kv.split("=", 1)
        key = key.strip()
        val = val.strip()

        # Convert val to appropriate type
        if val.lower() == "true":
            parsed_val = True
        elif val.lower() == "false":
            parsed_val = False
        elif val.lower() in ("none", "null"):
            parsed_val = None
        else:
            try:
                parsed_val = int(val)
            except ValueError:
                try:
                    parsed_val = float(val)
                except ValueError:
                    parsed_val = val

        if parsed_val is None:
            params.pop(key, None)
        else:
            params[key] = parsed_val

    # Unload model first if it's running so the parameters apply immediately on next run
    if model_entry.get("running"):
        _api("POST", f"/api/models/{model_entry['name']}/unload")

    payload = {
        "name": model_entry["name"],
        "file": model_entry["file"],
        "description": model_entry["description"],
        "aliases": model_entry["aliases"],
        "params": params,
        # Preserve non-text modality / backend / extra artifacts (e.g. vision
        # mmproj) so a `set` doesn't silently reset them to defaults.
        "modality": model_entry.get("modality", "text"),
        "backend": model_entry.get("backend", "llama-server"),
        "artifacts": model_entry.get("artifacts", {}),
        "mem_gb": model_entry.get("mem_gb", 0),
    }

    r = _api("POST", "/api/models/add", payload)
    if r.status_code == 200:
        _ok(f"Updated parameters for '{model_entry['name']}' to: {params}")
    else:
        _err(f"Failed to update model parameters: {r.json().get('detail', r.text)}")


