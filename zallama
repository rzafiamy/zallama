import threading

class Spinner:
    def __init__(self, message="Thinking..."):
        self.message = message
        self.running = False
        self.thread = None

    def _spin(self):
        chars = ["⠋", "⠙", "⠹", "⠸", "⠼", "⠴", "⠦", "⠧", "⠇", "⠏"]
        idx = 0
        while self.running:
            sys.stdout.write(f"\r{_color(chars[idx], F_BLUE + BOLD)} {F_DIM}{self.message}{RESET}")
            sys.stdout.flush()
            idx = (idx + 1) % len(chars)
            time.sleep(0.08)
        sys.stdout.write("\r" + " " * (len(self.message) + 15) + "\r")
        sys.stdout.flush()

    def start(self):
        self.running = True
        self.thread = threading.Thread(target=self._spin, daemon=True)
        self.thread.start()

    def stop(self):
        if self.running:
            self.running = False
            if self.thread:
                self.thread.join()

def cmd_run(args: list[str]):
    """Interactive chat: zallama run <model>"""
    if not args:
        _err("Usage: zallama run <model-name>")
        sys.exit(1)
    model = args[0]

    # Fetch model details to check modality
    r_models = _api("GET", "/api/models")
    if r_models.status_code == 200:
        models_info = r_models.json().get("models", [])
        model_entry = next((m for m in models_info if m["name"] == model), None)
        if model_entry and model_entry.get("modality") == "asr":
            _err(f"Model '{model}' is an ASR (Speech-to-Text) model and cannot be used in interactive chat.")
            _info("To transcribe audio with this model, use:")
            _info(f"  zallama transcribe {model} <audio-file.wav>")
            sys.exit(1)

    # Print a beautiful Fluent 2 style banner header
    print(_color("\n╭──────────────────────────────────────────────────────────╮", F_BLUE))
    print(f"{_color('│', F_BLUE)}  {BOLD}{F_WHITE}ZALLAMA INTERACTIVE CHAT{RESET}                             {_color('│', F_BLUE)}")
    model_line = f"Model: {model}"
    padded_model = model_line + " " * (52 - len(model_line))
    print(f"{_color('│', F_BLUE)}  {F_GRAY}{padded_model}{RESET} {_color('│', F_BLUE)}")
    info_line = "Type message and press Enter. /exit to quit."
    padded_info = info_line + " " * (52 - len(info_line))
    print(f"{_color('│', F_BLUE)}  {F_DIM}{padded_info}{RESET} {_color('│', F_BLUE)}")
    print(_color("╰──────────────────────────────────────────────────────────╯", F_BLUE))

    # First, ensure the model is loaded (may take a moment)
    print(_color(f"⏳ Loading model '{model}'...", F_ORANGE), end="", flush=True)
    r = _api("POST", f"/api/models/{model}/load")
    if r.status_code != 200:
        print()
        _err(f"Failed to load model: {r.json().get('detail', r.text)}")
        sys.exit(1)
    print(_color(" Ready!", F_TEAL))

    history = []

    while True:
        try:
            user_input = input(_color("\nUser › ", F_BLUE + BOLD)).strip()
        except (KeyboardInterrupt, EOFError):
            print("\n" + _color("Goodbye! 👋", F_DIM))
            break

        if not user_input:
            continue
        if user_input.lower() in ("/exit", "/quit", "exit", "quit"):
            print(_color("Goodbye! 👋", F_DIM))
            break
        if user_input == "/clear":
            history = []
            print(_color("History cleared.", F_DIM))
            continue

        history.append({"role": "user", "content": user_input})

        payload = {"model": model, "messages": history, "stream": True}
        spinner = Spinner("Thinking...")
        spinner.start()

        full_response = ""
        try:
            r = requests.post(
                f"{ZALLAMA_HOST}/v1/chat/completions",
                json=payload,
                stream=True,
                timeout=None,
            )
            
            if r.status_code != 200:
                spinner.stop()
                try:
                    err_msg = r.json().get("detail", r.text)
                except Exception:
                    err_msg = r.text
                print(_color(f"\nError: {err_msg}", F_RED))
                continue

            buffer = b""
            spinner_stopped = False
            in_reasoning = False
            in_content = False

            done = False
            for chunk in r.iter_content(chunk_size=None):
                if not spinner_stopped:
                    spinner.stop()
                    spinner_stopped = True

                buffer += chunk
                while b"\n" in buffer:
                    line_bytes, buffer = buffer.split(b"\n", 1)
                    line_str = line_bytes.decode("utf-8", errors="ignore").strip()
                    if not line_str:
                        continue
                    if line_str.startswith("data: "):
                        text = line_str[6:]
                    else:
                        text = line_str

                    if text == "[DONE]":
                        done = True
                        break

                    try:
                        chunk_json = json.loads(text)
                        delta = chunk_json["choices"][0]["delta"]
                        
                        reasoning_content = delta.get("reasoning_content", "")
                        delta_content = delta.get("content", "")
                        
                        if reasoning_content:
                            if not in_reasoning:
                                in_reasoning = True
                                print(f"\n{BOLD}{F_PURPLE}🧠 Thinking Process:{RESET}")
                            print(_color(reasoning_content, F_DIM), end="", flush=True)
                            full_response += reasoning_content
                        elif delta_content:
                            if in_reasoning:
                                in_reasoning = False
                                print(f"\n")
                            if not in_content:
                                in_content = True
                                print(f"\n{BOLD}{F_TEAL}🦙 Assistant:{RESET}")
                            print(delta_content, end="", flush=True)
                            full_response += delta_content
                    except Exception:
                        pass
                if done:
                    break

        except Exception as e:
            spinner.stop()
            print(_color(f"\nError: {e}", F_RED))
        except KeyboardInterrupt:
            spinner.stop()
            print(_color("\n[interrupted]", F_DIM))

        print()
        if full_response:
            history.append({"role": "assistant", "content": full_response})


def cmd_ps(args: list[str]):
    """Show running model processes."""
    r = _api("GET", "/api/ps")
    data = r.json()
    procs = data.get("processes", [])
    mem = data.get("memory", {})
    if not procs:
        print(_color("\nNo models currently running.", F_DIM))
        _print_mem_status(mem)
        return

    print(f"\n{BOLD}{F_BLUE} Running Model Processes{RESET}")
    headers = ["MODEL", "PORT", "MEMORY", "UPTIME", "LAST USED"]
    rows = []
    now = time.time()
    for p in procs:
        name = p["name"]
        port = str(p["port"])
        mem_gb = p.get("mem_gb", 0)
        mem_str = f"{mem_gb:.1f} GB" if mem_gb else "?"
        uptime = int(now - p.get("started_at", now))
        last = int(now - p.get("last_used", now))
        rows.append([
            _color(name, F_TEAL + BOLD),
            _color(port, F_BLUE),
            mem_str,
            _fmt_duration(uptime),
            f"{_fmt_duration(last)} ago"
        ])
    _print_table(headers, rows)
    _print_mem_status(mem)
    print()


def _print_mem_status(mem: dict):
    if not mem:
        return
    budget = mem.get("budget_gb") or 0
    loaded = mem.get("loaded_gb", 0)
    count = mem.get("loaded_count", 0)
    if budget > 0:
        head = mem.get("headroom_gb", 0)
        print(_color(f"\n  📊 Memory usage: {loaded:.1f} GB / {budget:.1f} GB used  •  {head:.1f} GB free  •  {count} model(s) loaded", F_BLUE))
    elif count:
        print(_color(f"\n  📊 Memory usage: {loaded:.1f} GB loaded across {count} model(s)", F_BLUE))


