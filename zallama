def _color(text: str, color_code: str) -> str:
    if sys.stdout.isatty():
        return f"{color_code}{text}{RESET}"
    return text


def _ok(msg: str): print(f"{_color('●', F_TEAL)} {msg}")
def _warn(msg: str): print(f"{_color('⚠', F_ORANGE)} {msg}", file=sys.stderr)
def _err(msg: str): print(f"{_color('✗', F_RED)} {msg}", file=sys.stderr)
def _info(msg: str): print(f"{_color('ℹ', F_BLUE)} {msg}")


def _print_table(headers: list[str], rows: list[list[str]], col_aligns: list[str] | None = None):
    """Render a clean Fluent-style table with elegant Unicode borders."""
    widths = [len(h) for h in headers]
    for row in rows:
        for idx, cell in enumerate(row):
            clean_cell = re.sub(r'\033\[[0-9;]*m', '', str(cell))
            widths[idx] = max(widths[idx], len(clean_cell))
    
    c_tl, c_tr, c_bl, c_br = "┌", "┐", "└", "┘"
    c_hl, c_vl, c_t = "─", "│", "┬"
    c_b, c_l, c_r = "┴", "├", "┤"
    c_x = "┼"
    
    top = c_tl + c_hl.join(c_hl * (w + 2) for w in widths) + c_tr
    print(_color(top, F_DIM))
    
    header_str = c_vl + c_vl.join(f" {h:<{widths[i]}} " for i, h in enumerate(headers)) + c_vl
    print(header_str)
    
    sep = c_l + c_x.join(c_hl * (w + 2) for w in widths) + c_r
    print(_color(sep, F_DIM))
    
    for row in rows:
        line_parts = []
        for i, cell in enumerate(row):
            clean_cell = re.sub(r'\033\[[0-9;]*m', '', str(cell))
            padding = widths[i] - len(clean_cell)
            align = col_aligns[i] if col_aligns else "left"
            if align == "right":
                line_parts.append(f" {' ' * padding}{cell} ")
            else:
                line_parts.append(f" {cell}{' ' * padding} ")
        print(c_vl + c_vl.join(line_parts) + c_vl)
        
    bot = c_bl + c_hl.join(c_hl * (w + 2) for w in widths) + c_br
    print(_color(bot, F_DIM))


